# devtools/kernel.debug.config
# Heavier debug instrumentation, merged ON TOP of kernel.config only when
# KERNEL_DEBUG=1 (e.g. `make qemu-setup-debug`, or KERNEL_DEBUG=1 in config.local).
# These slow the build/boot; KASAN ~doubles memory use -- bump QEMU_MEM to 2G.
#
# DEBUG_INFO, GDB_SCRIPTS, FRAME_POINTER and "KASLR off" already live in the
# base kernel.config (always on), so they are not repeated here.

# --- KASAN: on x86_64 the GENERIC flavour is the only valid one ---
CONFIG_KASAN=y
CONFIG_KASAN_GENERIC=y
CONFIG_KASAN_OUTLINE=y
# CONFIG_KASAN_INLINE is not set

# --- Memory-leak detector (catches "forgot kfree on rmmod") ---
CONFIG_DEBUG_KMEMLEAK=y

# --- Lock correctness: deadlocks, wrong lock context, sleep-in-atomic ---
CONFIG_PROVE_LOCKING=y
CONFIG_DEBUG_ATOMIC_SLEEP=y

# --- Richer tracing / dynamic probing ---
CONFIG_STACK_TRACER=y
CONFIG_KPROBES=y
CONFIG_KPROBE_EVENTS=y

# --- Expose the running kernel's config at /proc/config.gz ---
CONFIG_IKCONFIG=y
CONFIG_IKCONFIG_PROC=y
