# Minimal kernel config fragment for the QEMU dev guest (LEAN profile).
# Merged on top of `make defconfig` via scripts/kconfig/merge_config.sh.
# Heavier debug instrumentation lives in kernel.debug.config (KERNEL_DEBUG=1).

# --- Module support (core requirement) ---
CONFIG_MODULES=y
CONFIG_MODULE_UNLOAD=y
CONFIG_MODULE_FORCE_UNLOAD=y

# --- Initramfs boot ---
CONFIG_BLK_DEV_INITRD=y

# --- 9p over virtio: share the host project into the guest ---
CONFIG_NET=y
CONFIG_INET=y
CONFIG_NETWORK_FILESYSTEMS=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y

# --- Pseudo-filesystems commonly used by modules ---
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEBUG_FS=y
CONFIG_DEBUG_FS_ALLOW_ALL=y

# --- Networking core (handy once you reach netfilter; needed for 9p too) ---
CONFIG_NETDEVICES=y
CONFIG_NET_CORE=y

# --- Serial console ---
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_PRINTK=y
CONFIG_PRINTK_TIME=y

# --- GDB / symbol debugging (this template always builds vmlinux) ---
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF_TOOLCHAIN_DEFAULT=y
CONFIG_DEBUG_KERNEL=y
CONFIG_GDB_SCRIPTS=y
CONFIG_FRAME_POINTER=y
CONFIG_KALLSYMS=y
CONFIG_KALLSYMS_ALL=y
# Full debug info for GDB (defconfig may otherwise reduce it).
# CONFIG_DEBUG_INFO_REDUCED is not set
# BTF off: not needed for module debugging, avoids the pahole dependency
# and speeds up the build.
# CONFIG_DEBUG_INFO_BTF is not set

# Disable KASLR so GDB addresses are stable across boots
# CONFIG_RANDOMIZE_BASE is not set

# --- Basic ftrace (function/graph) for the rung-0 tracing exercise ---
# Idle overhead ~zero (dynamically patched in only on use). Stack tracer and
# kprobes are part of the DEBUG overlay, not the lean profile.
CONFIG_FTRACE=y
CONFIG_FUNCTION_TRACER=y
CONFIG_FUNCTION_GRAPH_TRACER=y
CONFIG_DYNAMIC_FTRACE=y

# Heavier debug instrumentation (KASAN, kmemleak, lockdep, kprobes) lives in
# devtools/kernel.debug.config, merged only with KERNEL_DEBUG=1
# (make qemu-setup-debug). Keep this base profile lean.

# --- Trim subsystems we never use, for a faster build/boot ---
# CONFIG_SOUND is not set
# CONFIG_USB is not set
# CONFIG_WIRELESS is not set
# CONFIG_WLAN is not set
# CONFIG_BLUETOOTH is not set
